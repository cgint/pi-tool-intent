  },
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "extension",
    "intent",
    "provenance"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "src",
    "tool-descriptions",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {},
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
